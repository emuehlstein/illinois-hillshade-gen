# ilhmp AWS worker configuration
# Copy to aws/.env and edit for your environment.

# AWS
AWS_REGION=us-east-2
KEY_PAIR_NAME=mapserver
SECURITY_GROUP=               # EC2 security group ID (must allow SSH inbound)
IAM_INSTANCE_PROFILE=         # IAM instance profile name (needs S3 read/write)
SSH_KEY=~/.ssh/mapserver-ec2.pem

# Worker defaults
INSTANCE_TYPE=c7g.2xlarge     # 8 ARM cores, 16GB RAM (~$0.14/hr spot)
DISK_GB=200                   # gp3 EBS volume

# Tile server (optional — for pull.sh to upload directly)
# TILE_SERVER_SSH=ubuntu@tiles.example.com
# TILE_SERVER_TILES_DIR=/data/tiles
